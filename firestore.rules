rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Public read of tallies. Writes only from signed-in users, and only +1 style updates.
    match /modelStats/{modelId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['up', 'down'])
        && request.resource.data.up is int
        && request.resource.data.down is int
        && request.resource.data.up >= 0
        && request.resource.data.down >= 0
        && (
          (request.resource.data.up == 1 && request.resource.data.down == 0) ||
          (request.resource.data.up == 0 && request.resource.data.down == 1)
        );

      allow update: if signedIn()
        && request.resource.data.keys().hasOnly(['up', 'down'])
        && request.resource.data.up is int
        && request.resource.data.down is int
        && resource.data.up is int
        && resource.data.down is int
        && (
          (request.resource.data.up == resource.data.up + 1
            && request.resource.data.down == resource.data.down) ||
          (request.resource.data.down == resource.data.down + 1
            && request.resource.data.up == resource.data.up)
        );

      allow delete: if false;
    }

    match /userVotes/{voteId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid', 'modelId', 'type', 'at'])
        && request.resource.data.uid == request.auth.uid
        && voteId == request.auth.uid + '_' + request.resource.data.modelId
        && request.resource.data.modelId is string
        && request.resource.data.modelId.size() > 0
        && request.resource.data.modelId.size() < 200
        && request.resource.data.type in ['up', 'down'];

      allow update, delete: if false;
    }

    /**
     * Account roles — CRITICAL SECURITY
     * Clients may create/update their own member profile and mark checkout_started.
     * Clients may NEVER set role to creator or change lastRenewal (only Admin SDK / Cloud Functions after Square verifies payment).
     */
    match /accounts/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.role == 'member'
        && request.resource.data.status in ['active', 'checkout_started']
        && (
          !('lastRenewal' in request.resource.data)
          || request.resource.data.lastRenewal == null
        );

      allow update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        // Role cannot be changed by the client (stays member, or stays creator if already granted by server)
        && request.resource.data.role == resource.data.role
        // lastRenewal cannot be set/changed by the client
        && (
          (!('lastRenewal' in request.resource.data) && !('lastRenewal' in resource.data))
          || request.resource.data.lastRenewal == resource.data.lastRenewal
        )
        // Members may only flip between active / checkout_started / expired (not self-upgrade)
        && request.resource.data.status in ['active', 'checkout_started', 'expired']
        // Block smuggling creator via other fields
        && request.resource.data.role in ['member', 'creator'];

      allow delete: if false;
    }

    // Legacy mirror — clients cannot mark themselves active creators
    match /creators/{uid} {
      allow read: if signedIn();

      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'checkout_started'
        && (
          !('lastRenewal' in request.resource.data)
          || request.resource.data.lastRenewal == null
        );

      allow update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == resource.data.status
        && (
          (!('lastRenewal' in request.resource.data) && !('lastRenewal' in resource.data))
          || request.resource.data.lastRenewal == resource.data.lastRenewal
        );

      allow delete: if false;
    }

    // Written only by Cloud Functions (Admin SDK). Clients cannot write.
    match /processedPayments/{id} {
      allow read: if false;
      allow write: if false;
    }
    match /pendingCheckouts/{id} {
      allow read: if signedIn() && (
        resource == null
        || resource.data.uid == request.auth.uid
        || id == request.auth.uid
      );
      allow write: if false;
    }
    match /unmatchedPayments/{id} {
      allow read, write: if false;
    }
  }
}
