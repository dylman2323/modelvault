rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read of tallies. Writes only from signed-in users, and only +1 style updates.
    match /modelStats/{modelId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['up', 'down'])
        && request.resource.data.up is int
        && request.resource.data.down is int
        && request.resource.data.up >= 0
        && request.resource.data.down >= 0
        && (
          (request.resource.data.up == 1 && request.resource.data.down == 0) ||
          (request.resource.data.up == 0 && request.resource.data.down == 1)
        );

      allow update: if request.auth != null
        && request.resource.data.keys().hasOnly(['up', 'down'])
        && request.resource.data.up is int
        && request.resource.data.down is int
        && resource.data.up is int
        && resource.data.down is int
        && (
          (request.resource.data.up == resource.data.up + 1
            && request.resource.data.down == resource.data.down) ||
          (request.resource.data.down == resource.data.down + 1
            && request.resource.data.up == resource.data.up)
        );

      allow delete: if false;
    }

    // One document per user+model. Create once; never update/delete (one vote only).
    match /userVotes/{voteId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid', 'modelId', 'type', 'at'])
        && request.resource.data.uid == request.auth.uid
        && voteId == request.auth.uid + '_' + request.resource.data.modelId
        && request.resource.data.modelId is string
        && request.resource.data.modelId.size() > 0
        && request.resource.data.modelId.size() < 200
        && request.resource.data.type in ['up', 'down'];

      allow update, delete: if false;
    }

    // Account status / roles — source of truth for member vs creator abilities.
    // role: member | creator
    // status: active | checkout_started | expired
    match /accounts/{uid} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.role in ['member', 'creator']
        && request.resource.data.status in ['active', 'checkout_started', 'expired']
        && (
          !('lastRenewal' in request.resource.data)
          || request.resource.data.lastRenewal == null
          || (request.resource.data.lastRenewal is string
              && request.resource.data.lastRenewal.size() == 10)
        );

      allow delete: if false;
    }

    // Legacy creators mirror (kept in sync from the client for roster emails)
    match /creators/{uid} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.status in ['checkout_started', 'active']
        && (
          request.resource.data.lastRenewal == null
          || (request.resource.data.lastRenewal is string
              && request.resource.data.lastRenewal.size() == 10)
        );

      allow delete: if false;
    }
  }
}
